  <diagram name="Prozess: Ingest &amp; Resolution" id="ingest">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="820" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="p-in" value="&lt;b&gt;Bytes rein&lt;/b&gt;&lt;br&gt;Drop · Picker · URL-Fetch (HostAdapter)&lt;br&gt;· VS-Code-Push (ingestFiles)" style="rounded=1;fillColor=#e0f2fe;strokeColor=#0284c7;html=1;fontSize=12;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="330" width="230" height="90" as="geometry" />
        </mxCell>
        <mxCell id="p-buffers" value="ingestBuffers" style="rounded=1;fillColor=#ffffff;strokeColor=#64748b;html=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="320" y="350" width="130" height="50" as="geometry" />
        </mxCell>
        <mxCell id="p-d1" value="Container?&lt;br&gt;(gzip/tar-Magic,&lt;br&gt;erste 512 B)" style="rhombus;fillColor=#fef3c7;strokeColor=#d97706;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="500" y="325" width="150" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p-ocm" value="&lt;b&gt;Worker: readOcmDelivery&lt;/b&gt;&lt;br&gt;gunzip → tar → CTF/Component-Archive klassifizieren&lt;br&gt;CDs → synthetische SPDX-Docs (ocm:// Namespaces)&lt;br&gt;SBOM-Blobs extrahiert, Refs per SHA-1 verdrahtet&lt;br&gt;Zip-Bomb-Caps · Links nie verfolgt" style="rounded=1;fillColor=#fef9c3;strokeColor=#ca8a04;html=1;fontSize=11;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="120" width="330" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p-d2" value="Compliance-&lt;br&gt;Profil?&lt;br&gt;(Sniff ≤ 64 KB)" style="rhombus;fillColor=#fef3c7;strokeColor=#d97706;html=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="700" y="325" width="150" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p-profile" value="&lt;b&gt;validateProfile (fail-closed)&lt;/b&gt;&lt;br&gt;unbekannter Check-Typ ⇒ Ablehnung&lt;br&gt;→ Store + Prefs (Cap 16 / 256 KB)&lt;br&gt;→ Quality-Section-Auswahl" style="rounded=1;fillColor=#f0fdf4;strokeColor=#16a34a;html=1;fontSize=11;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="660" y="560" width="270" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p-parse" value="&lt;b&gt;Worker: parse&lt;/b&gt;&lt;br&gt;sha1Hex (WebCrypto) · TextDecoder&lt;br&gt;detect content-based (nie Endung)&lt;br&gt;tag-value / JSON / YAML / OCM-CD&lt;br&gt;&lt;i&gt;Diagnostics statt Throws&lt;/i&gt;" style="rounded=1;fillColor=#fef9c3;strokeColor=#ca8a04;html=1;fontSize=11;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="910" y="310" width="250" height="130" as="geometry" />
        </mxCell>
        <mxCell id="p-batch" value="&lt;b&gt;EIN addLoadedBatch&lt;/b&gt;&lt;br&gt;buildIndexes (UI-Thread)&lt;br&gt;1 Commit = 1 Recompute&lt;br&gt;= 1 Render-Welle" style="rounded=1;fillColor=#ffffff;strokeColor=#64748b;html=1;fontSize=11;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1210" y="320" width="220" height="110" as="geometry" />
        </mxCell>
        <mxCell id="p-resolve" value="&lt;b&gt;computeResolutions&lt;/b&gt; — je ExternalDocumentRef:&lt;br&gt;1. manual (User-Bind) · 2. checksum (SHA-1 der Bytes) · 3. namespace (URI = documentNamespace)&lt;br&gt;Namens-Ähnlichkeit nur als Suggestion, nie auto" style="rounded=1;fillColor=#e0f2fe;strokeColor=#0284c7;html=1;fontSize=11;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1000" y="530" width="430" height="100" as="geometry" />
        </mxCell>
        <mxCell id="p-out" value="&lt;b&gt;Ergebnis&lt;/b&gt;&lt;br&gt;kaskadierender Tree · Map · Inventory/Conflicts/Diff&lt;br&gt;Unaufgelöstes = Placeholder (Fetch-URL / Datei / Bind)" style="rounded=1;fillColor=#f0fdf4;strokeColor=#16a34a;html=1;fontSize=11;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1030" y="680" width="370" height="90" as="geometry" />
        </mxCell>

        <mxCell id="p-e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#475569;html=1;" edge="1" parent="1" source="p-in" target="p-buffers"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p-e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#475569;html=1;" edge="1" parent="1" source="p-buffers" target="p-d1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p-e3" value="ja" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#ca8a04;html=1;fontSize=11;" edge="1" parent="1" source="p-d1" target="p-ocm"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p-e4" value="Entries rekursiv (Tiefe ≤ 1)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#ca8a04;html=1;fontSize=10;dashed=1;exitX=0;exitY=0.5;entryX=0.5;entryY=0;" edge="1" parent="1" source="p-ocm" target="p-buffers"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p-e5" value="nein" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#475569;html=1;fontSize=11;" edge="1" parent="1" source="p-d1" target="p-d2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p-e6" value="ja" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#16a34a;html=1;fontSize=11;" edge="1" parent="1" source="p-d2" target="p-profile"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p-e7" value="nein" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#475569;html=1;fontSize=11;" edge="1" parent="1" source="p-d2" target="p-parse"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p-e8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#475569;html=1;" edge="1" parent="1" source="p-parse" target="p-batch"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p-e9" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#475569;html=1;" edge="1" parent="1" source="p-batch" target="p-resolve"><mxGeometry relative="1" as="geometry" /></mxCell>

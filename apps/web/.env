# SBOM-Lens flavor defaults (all modes inherit; .env.<mode> overrides).
VITE_APP_TITLE=SBOM Lens
VITE_APP_DESCRIPTION=SBOM Lens — a fast, minimal viewer for SPDX SBOMs, including cascading document hierarchies. Runs entirely in your browser.
VITE_APP_FAVICON=./favicon.svg
# Accent ramp on <html> (see index.css). Empty = the default sky ramp.
VITE_FLAVOR_CLASS=

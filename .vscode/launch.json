{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run SBOM Lens extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/apps/vscode"],
      "outFiles": ["${workspaceFolder}/apps/vscode/out/**/*.js"],
      "preLaunchTask": "sbomlens: compile extension"
    }
  ]
}
